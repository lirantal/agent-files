{
  "name": "agent-files",
  "description": "A library that provides, detects and parses files used by coding agents and other AI tools so you don't have to reinvent the track them yourself",
  "version": "1.0.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.mjs"
    },
    "./dist/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.mjs",
      "require": "./dist/*.cjs"
    }
  },
  "engines": {
    "npm": ">=11.10.0",
    "node": ">=24.0.0"
  },
  "files": [
    "dist",
    "src",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint . && npm run lint:markdown",
    "lint:markdown": "npx --no-install markdownlint-cli -c .github/.markdownlint.yml -i '.git' -i '__tests__' -i '.github' -i '.changeset' -i 'CODE_OF_CONDUCT.md' -i 'CHANGELOG.md' -i 'docs/**' -i '__template__draft_/**' -i 'node_modules' -i 'dist' -i '__template__' '**/**.md'",
    "lint:fix": "eslint . --fix",
    "test": "c8 node --import tsx --test __tests__/**/*.test.ts",
    "test:watch": "c8 node --import tsx --test --watch __tests__/**/*.test.ts",
    "coverage:view": "open coverage/lcov-report/index.html",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@changesets/changelog-git": "^0.2.1",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "c8": "^11.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-n": "^18.1.0",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.0.11",
    "lint-staged": "^17.0.8",
    "markdownlint-cli": "0.49.0",
    "tsup": "^8.1.0",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "validate-conventional-commit": "^1.0.4"
  },
  "lint-staged": {
    "**/*.{js,json}": [
      "npm run lint:fix"
    ]
  },
  "homepage": "https://github.com/lirantal/agent-files",
  "bugs": {
    "url": "https://github.com/lirantal/agent-files/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lirantal/agent-files.git"
  },
  "keywords": [
    "mcp",
    "model context protocol",
    "ai agents",
    "agent files",
    "agent metadata"
  ],
  "publishConfig": {
    "provenance": true,
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "license": "Apache-2.0",
  "c8": {
    "exclude": [
      "dist/**",
      "coverage/**",
      "__tests__/**",
      "**/*.test.ts",
      "**/*.test.js"
    ],
    "include": [
      "src/**"
    ],
    "reporter": [
      "text",
      "lcov",
      "html"
    ]
  },
  "author": {
    "name": "Liran Tal",
    "email": "liran.tal@gmail.com",
    "url": "https://github.com/lirantal"
  }
}
